EXPO_PUBLIC_API_BASE_URL=https://kura-api-fiap.azurewebsites.net
EXPO_PUBLIC_LUNA_BASE_URL=https://kura-luna-python.azurewebsites.net
EXPO_PUBLIC_USE_MOCKS=true
# Header X-API-Key enviado em toda chamada ao lunaClient (ver services/api/client.ts).
# Deve bater com LUNA_INBOUND_API_KEY da Luna (kura-luna-ai/luna/.env) — sem isto,
# POST /whatsapp/enviar responde 401 mesmo com o app configurado corretamente.
EXPO_PUBLIC_LUNA_API_KEY=kura-luna-inbound-key-2026
